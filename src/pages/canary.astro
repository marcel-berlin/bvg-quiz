---
// src/pages/canary.astro
import BaseLayout from "../layouts/BaseLayout.astro";
import Card from "../components/Card.astro";
import ResultHero from "../components/ResultHero.astro";

// Contact hrefs come from Vercel env vars (PII out of repo).
// Set PUBLIC_CANARY_WHATSAPP (e.g. 4915XXXXXXX, no '+', no spaces)
// and PUBLIC_CANARY_EMAIL (e.g. someone@example.com) in the Vercel
// dashboard before sharing the /canary link with testers.
// Astro inlines PUBLIC_* env vars into the static HTML at build time.
const waNumber = import.meta.env.PUBLIC_CANARY_WHATSAPP ?? "";
const mailAddr = import.meta.env.PUBLIC_CANARY_EMAIL ?? "";
const waHref = waNumber ? `https://wa.me/${waNumber}` : "https://wa.me/";
const mailHref = mailAddr ? `mailto:${mailAddr}` : "mailto:";
---
<BaseLayout lang="de" title="BVG Quiz Canary — Voice-Test">
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <main class="max-w-2xl mx-auto px-6 py-12 space-y-12">
    <header>
      <h1 class="text-display-h1 font-bold">Voice-Canary</h1>
      <p class="mt-2 text-text-muted">
        Drei Probefragen + ein Probe-Result. Bitte einmal lesen
        und unten Bescheid geben — danke.
      </p>
    </header>

    <section aria-labelledby="probe-fragen" class="space-y-4">
      <h2 id="probe-fragen" class="text-display-h2 font-bold">Probefragen</h2>

      <Card>
        <h3 class="text-h3 font-semibold">Frage 1</h3>
        <p class="mt-2 text-body">
          Sonntag, 14:00. Wo bist du? — und wir bitten höflich um eine ehrliche Antwort.
        </p>
      </Card>

      <Card>
        <h3 class="text-h3 font-semibold">Frage 2</h3>
        <p class="mt-2 text-body">
          Du hast 3 Minuten Umsteigezeit am Hermannplatz. Was machst du?
        </p>
      </Card>

      <Card>
        <h3 class="text-h3 font-semibold">Frage 3</h3>
        <p class="mt-2 text-body">
          Es ist 22:47. Der nächste Zug fährt in 9 Minuten. Auf dem Bahnsteig:
        </p>
      </Card>
    </section>

    <section aria-labelledby="probe-result" class="space-y-4">
      <h2 id="probe-result" class="sr-only">Probe-Result</h2>
      <ResultHero
        line="u8"
        shortName="U8"
        schluesselwort="Schicksalslinie"
        headline="Du fährst nicht U8. Die U8 fährt dich."
      />
      <Card as="article">
        <p class="text-body">
          Die U8 ist keine Linie, die du wählst. Sie ist eine, die dich findet —
          meistens am Kotti, meistens nach Mitternacht. Du steigst ein, weil
          etwas dich ruft, und du steigst aus, wenn die U8 entscheidet, dass
          es Zeit ist. Heinrich-Heine, Hermannstraße, Schönleinstraße —
          die Stationen sind keine Orte, sondern Zustände. Pünktlichkeit
          ist hier Verhandlungssache, aber sie hält am Ende immer ihr Wort:
          du kommst an. Vielleicht nicht da, wo du wolltest. Aber genau da,
          wo du heute hingehörst.
        </p>
      </Card>
    </section>

    <footer class="border-t pt-6 text-text-muted">
      <p class="text-body">
        Wie klingt das? Schreib mir kurz — was sich anfühlt wie BVG, und was
        nicht.
      </p>
      <p class="mt-2 text-body">
        <a href={waHref} class="underline">WhatsApp</a>
        &nbsp;·&nbsp;
        <a href={mailHref} class="underline">Mail</a>
      </p>
      <p class="mt-4 text-caption">
        Diese Seite ist noindex und nicht von der Hauptnav verlinkt —
        direkter Link only. Kontakt-Daten werden via Vercel-Env-Vars
        (PUBLIC_CANARY_WHATSAPP / PUBLIC_CANARY_EMAIL) injiziert,
        damit keine PII im Repo landet.
      </p>
    </footer>
  </main>
</BaseLayout>
