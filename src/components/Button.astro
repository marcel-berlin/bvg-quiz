---
// src/components/Button.astro
// Discriminated-union Props: `type` is type-level mutually exclusive with `href`.
// Caller writing <Button href="/foo" type="submit"> is now a TypeScript error
// instead of silently dropping the `type` prop on the floor (WR-02).
type ButtonProps = {
  variant?: "primary" | "secondary";
  href?: undefined;
  type?: "button" | "submit";
};
type AnchorProps = {
  variant?: "primary" | "secondary";
  href: string;
  type?: never;
};
type Props = ButtonProps | AnchorProps;

const props = Astro.props as Props;
const variant = props.variant ?? "primary";
const href = "href" in props ? props.href : undefined;
const type = href === undefined ? ((props as ButtonProps).type ?? "button") : undefined;

const base =
  "inline-flex items-center gap-2 px-6 py-3 rounded-md font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-text-dark";

// D-18 ENFORCEMENT: bg-bvg-yellow + text-text-dark are hardwired as a pair
// in variants.primary. Neither can be used alone — accidental misuse blocked.
const variants = {
  primary: "bg-bvg-yellow text-text-dark hover:bg-bvg-yellow-dark",
  secondary: "bg-surface-card text-text-dark hover:bg-bvg-yellow hover:text-text-dark border border-text-dark",
};
const cls = `${base} ${variants[variant]}`;

const Tag = href ? "a" : "button";
---
<Tag class={cls} href={href} type={type}>
  <slot />
</Tag>
