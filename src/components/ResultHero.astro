---
// src/components/ResultHero.astro
interface Props {
  line: "u1" | "u2" | "u3" | "u4" | "u5" | "u6" | "u7" | "u8" | "u9";
  shortName: string;       // "U8"
  schluesselwort: string;  // "Schicksalslinie"
  headline: string;        // "Du fährst nicht U8. Die U8 fährt dich."
}
const { line, shortName, schluesselwort, headline } = Astro.props;

// CRITICAL — Tailwind JIT class-discovery safety:
// Tailwind v4's JIT scanner only finds class literals at build-time scan.
// `bg-line-${line}` as a bare template literal would NOT be discovered —
// the explicit 9-key map below guarantees all 9 utility classes are
// present as literals. Source: PATTERNS.md "Tailwind v4 JIT Class-Discovery Safety".
const lineClass = {
  u1: "bg-line-u1",
  u2: "bg-line-u2",
  u3: "bg-line-u3",
  u4: "bg-line-u4",
  u5: "bg-line-u5",
  u6: "bg-line-u6",
  u7: "bg-line-u7",
  u8: "bg-line-u8",
  u9: "bg-line-u9",
}[line];

// WCAG 2.1 AA contrast: white text fails on light line colours (U1, U2, U4, U7, U9).
// Per-line text colour, computed against the hexes in global.css:20-28.
// All combinations clear the 4.5:1 body-text threshold.
// See .planning/visual/design-system.md "Per-Line Text Colour" + 02-REVIEW.md CR-01.
const textClass = {
  u1: "text-text-dark",
  u2: "text-text-dark",
  u3: "text-white",
  u4: "text-text-dark",
  u5: "text-white",
  u6: "text-text-dark",
  u7: "text-text-dark",
  u8: "text-white",
  u9: "text-text-dark",
}[line];
---
<header class={`relative px-6 py-12 ${lineClass} ${textClass}`}>
  <div class="flex items-baseline gap-3">
    <span
      class="font-display font-bold text-5xl leading-none"
      aria-hidden="true"
    >{shortName}</span>
    <span class="text-caption uppercase tracking-wide font-medium">
      {schluesselwort}
    </span>
  </div>
  <h1 class="mt-4 text-display-h1 font-bold max-w-2xl">{headline}</h1>
</header>
